// difficulty plugin：监听 ChangeDifficulty → 更新 Board → emit RestartGame。
//
// 与参考项目 bevy-lab/difficulty.rs 对齐：UI 不直接重置 Board，而是 emit
// 一个语义事件，由 difficulty plugin 集中处理参数变更。
(
    dependencies: ["board", "cell"],
    events: [
        // 字段：which 为 "Easy" / "Med" / "Hard"。
        (name: "ChangeDifficulty", default: (which: "")),
    ],
    systems: [
        // 必须 after ui::input_router——difficulty 按钮的 PickClick 由
        // input_router 翻译成 ChangeDifficulty 事件，本系统才能同帧消费；
        // dynamic 事件 buffer 帧末清空，跨帧不可读。
        // 同时排在 cell 前——difficulty 处理 ChangeDifficulty 后 emit
        // RestartGame，让 cell 同帧消费完成清空 + reset。
        Script(
            path: "difficulty.rhai",
            after: ["ui::input_router"],
            before: ["cell"],
        ),
    ],
)
