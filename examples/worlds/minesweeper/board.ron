// board plugin：棋盘元数据 + 初始 layout。
//
// 状态字段：
// - layout_built: tile 实体是否已 spawn
// - mines_placed: 是否已布雷（首次 reveal 触发）
// - state: 0=playing 1=won 2=lost
// - start_time: 首次点击时刻（time() 的快照），timer plugin 用来算 elapsed
//
// 这里只声明组件——init_layout 在 board.rhai 里跑。
(
    components: [
        (
            name: "Board",
            default: (
                width: 8,
                height: 8,
                mine_count: 10,
                layout_built: 0,
                mines_placed: 0,
                state: 0,
                start_time: 0.0,
            ),
        ),
        // 棋盘 grid 容器 marker——restart 时 despawn 它整棵子树（含 row /
        // tile / label），下一帧由 board.rhai 用新尺寸重建。
        (name: "BoardGrid", default: ()),
        // HUD slot：board 第一帧 spawn 的空 status bar 容器，hud.rhai 把
        // 难度按钮 / 文字往里 append。先 spawn HUD slot 再 spawn BoardGrid，
        // 保证两者顺序（slot top, grid bottom）跨 restart 不变。
        (name: "HudSlot", default: ()),
    ],
    systems: [
        Script(path: "board.rhai"),
    ],
)
