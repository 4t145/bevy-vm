// orbit demo：三个 mesh 在世界里弹跳。
//
// 单 World 架构后，视觉组件由脚本 setup.rhai 在第一帧通过 attach_* host fn
// 挂到 Bevy 主世界。位置 / 速度走自家声明的 dynamic Pos/Vel 组件。
(
    components: [
        (name: "Pos", default: (x: 0.0, y: 0.0, z: 0.0)),
        (name: "Vel", default: (x: 0.0, y: 0.0, z: 0.0)),
        (name: "Mover", default: (
            bound: 5.0,
            color_r: 1.0, color_g: 1.0, color_b: 1.0,
            shape: "Cuboid",
            size: 1.0,
        )),
        (name: "OrbitCamera", default: ()),
        (name: "SetupState", default: (done: 0)),
    ],
    entities: [
        (components: {
            "Pos": (x: -4.0, y: 0.0, z: 0.0),
            "Vel": (x: 0.08, y: 0.0, z: 0.0),
            "Mover": (
                bound: 4.0,
                color_r: 0.9, color_g: 0.3, color_b: 0.3,
                shape: "Cuboid",
                size: 1.0,
            ),
        }),
        (components: {
            "Pos": (x: 0.0, y: 0.0, z: 0.0),
            "Vel": (x: 0.0, y: 0.06, z: 0.0),
            "Mover": (
                bound: 3.0,
                color_r: 0.3, color_g: 0.6, color_b: 0.9,
                shape: "Sphere",
                size: 0.7,
            ),
        }),
        (components: {
            "Pos": (x: 4.0, y: 0.0, z: 0.0),
            "Vel": (x: 0.0, y: 0.0, z: 0.1),
            "Mover": (
                bound: 5.0,
                color_r: 0.4, color_g: 0.85, color_b: 0.4,
                shape: "Cuboid",
                size: 0.8,
            ),
        }),
        (components: {
            "OrbitCamera": (),
        }),
        (components: {
            "SetupState": (done: 0),
        }),
    ],
    systems: [
        Script(path: "setup.rhai"),
        Script(path: "bounce.rhai"),
    ],
)
