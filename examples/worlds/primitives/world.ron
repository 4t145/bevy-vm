// primitives demo：9 个 Bevy 原生几何图元 + 一块地面，自转展示。
//
// 单 World 架构：所有视觉组件由 setup.rhai 第一帧调 attach_* 挂上。
(
    components: [
        (name: "Spin", default: (
            speed: 0.0,
            color_r: 1.0, color_g: 1.0, color_b: 1.0,
            shape: "Cube",
            x: 0.0,
            metallic: 0.0,
            roughness: 0.6,
            yaw_deg: 0.0,
        )),
        (name: "Ground", default: ()),
        (name: "PrimitivesCamera", default: ()),
        (name: "PrimitivesSetup", default: (done: 0)),
    ],
    entities: [
        (components: { "Spin": (x: -8.0, color_r: 0.9, color_g: 0.3, color_b: 0.3, shape: "Cube", speed: 0.8) }),
        (components: { "Spin": (x: -6.0, color_r: 0.9, color_g: 0.6, color_b: 0.2, shape: "Sphere", speed: 0.8, metallic: 0.8, roughness: 0.3) }),
        (components: { "Spin": (x: -4.0, color_r: 0.4, color_g: 0.8, color_b: 0.4, shape: "Cylinder", speed: 0.8) }),
        (components: { "Spin": (x: -2.0, color_r: 0.3, color_g: 0.7, color_b: 0.9, shape: "Capsule", speed: 0.8) }),
        (components: { "Spin": (x: 0.0, color_r: 0.8, color_g: 0.5, color_b: 0.9, shape: "Cone", speed: 0.8) }),
        (components: { "Spin": (x: 2.0, color_r: 0.9, color_g: 0.8, color_b: 0.3, shape: "ConicalFrustum", speed: 0.8) }),
        (components: { "Spin": (x: 4.0, color_r: 0.5, color_g: 0.5, color_b: 0.95, shape: "Torus", speed: 0.8, metallic: 0.6, roughness: 0.4) }),
        (components: { "Spin": (x: 6.0, color_r: 0.95, color_g: 0.4, color_b: 0.6, shape: "Tetrahedron", speed: 0.8) }),
        (components: { "Ground": () }),
        (components: { "PrimitivesCamera": () }),
        (components: { "PrimitivesSetup": (done: 0) }),
    ],
    systems: [
        Script(path: "setup.rhai"),
        Script(path: "spin.rhai"),
    ],
)
