// drag demo：鼠标拖动一个立方体。
//
// 单 World 架构：视觉与相机由 setup.rhai 第一帧 attach。
(
    components: [
        (name: "DragState", default: (active: 0, x: 0.0, y: 0.0)),
        (name: "DragCam", default: ()),
        (name: "DragSetup", default: (done: 0)),
    ],
    entities: [
        (components: { "DragState": (active: 0, x: 0.0, y: 0.0) }),
        (components: { "DragCam": () }),
        (components: { "DragSetup": (done: 0) }),
    ],
    systems: [
        Script(path: "setup.rhai"),
        Script(path: "drag.rhai"),
    ],
)
