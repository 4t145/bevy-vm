// 通用 3D 物体检视器：相机绕原点的轨道相机。
//
// 单 World 架构：视觉与 Camera3d 由 setup.rhai 第一帧 attach。
(
    components: [
        (
            name: "Zoom",
            default: (
                distance: 6.0,
                min_distance: 2.0,
                max_distance: 30.0,
                speed: 0.5,
            ),
        ),
        (
            name: "Orbit",
            default: (
                yaw: 0.0,
                pitch: 0.0,
                active: 0,
                sensitivity: 0.005,
            ),
        ),
        (name: "Subject", default: ()),
        (name: "OrbitCam", default: ()),
        (name: "OrbitSetup", default: (done: 0)),
    ],
    entities: [
        (components: { "Subject": () }),
        (components: { "OrbitCam": (), "Zoom": (distance: 6.0), "Orbit": (yaw: 0.0, pitch: 0.0) }),
        (components: { "OrbitSetup": (done: 0) }),
    ],
    systems: [
        Script(path: "setup.rhai"),
        Script(path: "object_viewer_3d.rhai"),
    ],
)
