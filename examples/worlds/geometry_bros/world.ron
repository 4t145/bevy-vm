// 几何体兄弟（Geometry Bros）：仿土豆兄弟 / Vampire Survivors 的 MVP，
// 完全用 Bevy 内置几何体素材，3D 正交俯视。
//
// module 拓扑（dependencies = 类型注册顺序，before/after = 调度顺序）：
//   player ← enemy ← shooting ← projectile ← combat ← xp ← level ← upgrade ← death
//   pause / hud / camera 横向独立
//
// 视觉组件由各 module 自己 spawn 或 setup.rhai 在第一帧 attach（player /
// 地面 / 相机集中在 player module 的 setup）。
(
    seed: Some(20251211),
    modules: [
        "player",
        "enemy",
        "shooting",
        "projectile",
        "combat",
        "xp",
        "level",
        "wave",
        "pause",
        "upgrade",
        "hud",
        "death",
        "camera",
    ],
    components: [
        // 地面 marker——player::setup.rhai 第一帧 attach mesh。
        (name: "Ground", default: ()),
    ],
    entities: [
        // 玩家：单例。视觉 / Transform 由 player::setup.rhai 第一帧挂上。
        (components: {
            "player::Player": (
                hp: 100,
                max_hp: 100,
                speed: 5.0,
                attack_cooldown: 0.5,
                attack_timer: 0.0,
                bullet_damage: 10,
                bullet_speed: 8.0,
                bullet_lifetime: 2.0,
                regen: 0.0,
                kills: 0,
                survived: 0.0,
            ),
        }),
        // 地面 marker。
        (components: { "Ground": () }),
    ],
)
