// player module：玩家组件 + WASD 移动 + 第一帧视觉/相机/地面 attach。
//
// Player 单例由 world.ron 直接 spawn——这里只声明组件 schema 和挂逻辑。
(
    components: [
        (
            name: "Player",
            default: (
                hp: 100,
                max_hp: 100,
                speed: 5.0,
                attack_cooldown: 0.5,
                attack_timer: 0.0,
                bullet_damage: 10,
                bullet_speed: 8.0,
                bullet_lifetime: 2.0,
                regen: 0.0,            // HP/秒——靠波次菜单的 regen 卡片增长
                kills: 0,
                survived: 0.0,
                key_w: 0, key_a: 0, key_s: 0, key_d: 0,
                setup_done: 0,         // setup.rhai 单次标记
            ),
        ),
        (name: "MainCamera", default: ()),
    ],
    entities: [
        (components: { "MainCamera": () }),
    ],
    systems: [
        Script(path: "setup.rhai"),
        Script(path: "player.rhai", run_if: ["!is_paused()"]),
    ],
)
